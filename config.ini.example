[API]
# =============================================================================
# API 密钥配置
# =============================================================================
# 请填入你的 API 密钥
# - 通义千问: 前往 https://dashscope.aliyun.com/ 获取
# - DeepSeek: 前往 https://platform.deepseek.com/ 获取
#
# 注意：
# 1. 将此文件复制为 config.ini 后再修改
# 2. config.ini 不会被上传到 GitHub（已加入 .gitignore）
# 3. 不要将真实的 API 密钥提交到代码仓库！
# =============================================================================
api_key=your_api_key_here


# =============================================================================
# 模型选择
# =============================================================================
# 支持两种 API 服务，根据模型名称自动识别：
#
# 【通义千问 - 阿里云】
# 模型列表：
#   - qwen-turbo    : 快速、便宜，适合大多数场景
#   - qwen-plus     : 性能均衡
#   - qwen-max      : 最强性能，价格较高
#
# 【DeepSeek】
# 模型列表：
#   - deepseek-chat      : 通用对话模型
#   - deepseek-coder     : 代码专用模型
#   - deepseek-reasoner  : 推理模型
#
# 使用方法：直接填写模型名称，程序会自动选择对应的 API 端点
# =============================================================================
model=qwen-turbo


# =============================================================================
# 并发线程数
# =============================================================================
# 说明：
# - 通义千问：建议 3-5，超过可能导致速率限制
# - DeepSeek：可以适当调高（10-20），DeepSeek 不限制并发
#
# 根据你的 API 套餐和网速调整，如果经常超时请降低此值
# =============================================================================
max_workers=5


# =============================================================================
# 请求超时时间（秒）
# =============================================================================
# 说明：
# - 文档翻译可能需要较长时间，建议设置 60-180 秒
# - 如果网络不稳定或文档较大，请增加此值
# =============================================================================
timeout=120


# =============================================================================
# 配置示例
# =============================================================================
# 【示例 1：使用通义千问】
# api_key=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# model=qwen-turbo
# max_workers=5
# timeout=120
#
# 【示例 2：使用 DeepSeek】
# api_key=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# model=deepseek-chat
# max_workers=10
# timeout=120
# =============================================================================
